# ============================================================
# PACR — Production Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --- Database ---
DB_ROOT_PASSWORD=changeme_root_password
DB_NAME=pacr
DB_USERNAME=pacr
DB_PASSWORD=changeme_db_password

# --- JWT (min. 32 characters, generate with: openssl rand -base64 48) ---
JWT_SECRET=changeme_generate_a_secure_random_string_here

# --- CORS (your server IP or domain, comma-separated) ---
APP_CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# --- Strava OAuth (optional, leave empty to disable) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://YOUR_SERVER_IP/api/strava/callback
STRAVA_FRONTEND_URL=http://YOUR_SERVER_IP

# --- Mail / SMTP (optional, leave empty to disable) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- AI (optional, leave empty to disable) ---
PACR_AI_API_KEY=
