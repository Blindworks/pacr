<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="047-create-cycle-entries" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="cycle_entries"/>
            </not>
        </preConditions>
        <createTable tableName="cycle_entries">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_cycle_entries_user"
                             references="users(id)"/>
            </column>
            <column name="entry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="physical_symptoms" type="VARCHAR(500)"/>
            <column name="mood" type="VARCHAR(50)"/>
            <column name="energy_level" type="INT"/>
            <column name="sleep_hours" type="INT"/>
            <column name="sleep_minutes" type="INT"/>
            <column name="sleep_quality" type="VARCHAR(20)"/>
            <column name="flow_intensity" type="VARCHAR(20)"/>
            <column name="notes" type="VARCHAR(1000)"/>
        </createTable>

        <createIndex tableName="cycle_entries" indexName="idx_cycle_entries_user_date">
            <column name="user_id"/>
            <column name="entry_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
