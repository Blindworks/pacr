<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="050-1" author="codex">
        <addColumn tableName="training_steps">
            <column name="duration_seconds" type="INT"/>
            <column name="distance_meters" type="INT"/>
        </addColumn>
    </changeSet>

    <changeSet id="050-2" author="codex">
        <dropNotNullConstraint tableName="training_steps" columnName="title" columnDataType="VARCHAR(200)"/>
    </changeSet>
</databaseChangeLog>
