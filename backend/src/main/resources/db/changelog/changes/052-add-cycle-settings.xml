<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="052-create-cycle-settings" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="cycle_settings"/>
            </not>
        </preConditions>
        <createTable tableName="cycle_settings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_cycle_settings_user"
                             references="users(id)"/>
            </column>
            <column name="first_day_of_last_period" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="average_cycle_length" type="INT" defaultValueNumeric="28">
                <constraints nullable="false"/>
            </column>
            <column name="average_period_duration" type="INT" defaultValueNumeric="5">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
