<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

  <changeSet id="055-create-asthma-entries" author="dev">
    <preConditions onFail="MARK_RAN"><not><tableExists tableName="asthma_entries"/></not></preConditions>
    <createTable tableName="asthma_entries">
      <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
      <column name="user_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_asthma_user" references="users(id)"/></column>
      <column name="logged_at" type="TIMESTAMP"><constraints nullable="false"/></column>
      <column name="symptoms" type="VARCHAR(255)"/>
      <column name="severity_score" type="INT"/>
      <column name="peak_flow_l_min" type="INT"/>
      <column name="inhaler_usage" type="VARCHAR(20)" defaultValue="NONE"/>
      <column name="notes" type="TEXT"/>
    </createTable>
    <createIndex tableName="asthma_entries" indexName="idx_asthma_user_logged_at">
      <column name="user_id"/><column name="logged_at"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
