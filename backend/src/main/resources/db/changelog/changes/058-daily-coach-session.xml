<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="058-create-daily-coach-sessions" author="dev">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="daily_coach_sessions"/></not>
        </preConditions>
        <createTable tableName="daily_coach_sessions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_coach_session_user" references="users(id)"/>
            </column>
            <column name="session_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="wellbeing_context_json" type="TEXT"/>
            <column name="user_feeling_score" type="INT"/>
            <column name="user_feeling_text" type="VARCHAR(500)"/>
            <column name="ai_recommendation" type="TEXT"/>
            <column name="ai_suggested_action" type="VARCHAR(20)"/>
            <column name="user_decision" type="VARCHAR(20)"/>
            <column name="restructuring_summary_json" type="TEXT"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
