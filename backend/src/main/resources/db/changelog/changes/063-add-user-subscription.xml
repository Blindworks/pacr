<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="063-add-subscription-plan" author="system">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="users" columnName="subscription_plan"/></not>
        </preConditions>
        <addColumn tableName="users">
            <column name="subscription_plan" type="VARCHAR(20)" defaultValue="FREE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="063-add-subscription-expires-at" author="system">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="users" columnName="subscription_expires_at"/></not>
        </preConditions>
        <addColumn tableName="users">
            <column name="subscription_expires_at" type="DATETIME"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
