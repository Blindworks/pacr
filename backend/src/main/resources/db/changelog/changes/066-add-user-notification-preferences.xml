<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="066-add-user-notification-preferences" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="user_notification_preferences"/></not>
        </preConditions>
        <createTable tableName="user_notification_preferences">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                    foreignKeyName="fk_notif_prefs_user" references="users(id)"/>
            </column>
            <column name="email_reminder_enabled" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="email_reminder_time" type="VARCHAR(5)" defaultValue="18:00"/>
            <column name="email_news_enabled" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
