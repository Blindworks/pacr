<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="067-add-app-news" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="app_news"/></not>
        </preConditions>
        <createTable tableName="app_news">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_user_id" type="BIGINT">
                <constraints foreignKeyName="fk_news_creator" references="users(id)"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="published_at" type="DATETIME"/>
            <column name="is_published" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
