<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="068-add-app-news-sent-log" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="app_news_sent_log"/></not>
        </preConditions>
        <createTable tableName="app_news_sent_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_sent_log_user" references="users(id)"/>
            </column>
            <column name="news_id" type="BIGINT">
                <constraints foreignKeyName="fk_sent_log_news" references="app_news(id)"/>
            </column>
            <column name="sent_at" type="DATETIME"/>
        </createTable>
        <addUniqueConstraint tableName="app_news_sent_log" columnNames="user_id,news_id"
            constraintName="uq_news_sent_user_news"/>
    </changeSet>
</databaseChangeLog>
