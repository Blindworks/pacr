<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="069-add-achievements" author="system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="achievements"/></not>
        </preConditions>
        <createTable tableName="achievements">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="achievement_key" type="VARCHAR(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_achievement_key"/>
            </column>
            <column name="name" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="icon" type="VARCHAR(100)"/>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="threshold" type="DOUBLE" defaultValueNumeric="0"/>
            <column name="sort_order" type="INT" defaultValueNumeric="0"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
