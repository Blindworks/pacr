<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="077-1" author="claude">
        <comment>Create route_attempts table for tracking community route attempts and leaderboards</comment>
        <createTable tableName="route_attempts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="route_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="activity_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="time_seconds" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="pace_seconds_per_km" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="completed_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="route_attempts" baseColumnNames="route_id"
            referencedTableName="community_routes" referencedColumnNames="id"
            constraintName="fk_route_attempts_route"/>
        <addForeignKeyConstraint
            baseTableName="route_attempts" baseColumnNames="user_id"
            referencedTableName="users" referencedColumnNames="id"
            constraintName="fk_route_attempts_user"/>
        <addForeignKeyConstraint
            baseTableName="route_attempts" baseColumnNames="activity_id"
            referencedTableName="completed_trainings" referencedColumnNames="id"
            constraintName="fk_route_attempts_activity"/>
        <createIndex tableName="route_attempts" indexName="idx_route_attempts_route_status">
            <column name="route_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="route_attempts" indexName="idx_route_attempts_user_pending">
            <column name="user_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
