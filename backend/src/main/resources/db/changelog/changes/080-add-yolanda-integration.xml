<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="080-1" author="claude">
        <comment>Create yolanda_token table for Yolanda smart scale OAuth integration</comment>
        <createTable tableName="yolanda_token">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="account_id" type="VARCHAR(100)">
                <constraints nullable="true" unique="true" uniqueConstraintName="uk_yolanda_token_account_id"/>
            </column>
            <column name="access_token" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="refresh_token" type="VARCHAR(1000)">
                <constraints nullable="true"/>
            </column>
            <column name="expires_at" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="nickname" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="yolanda_token" baseColumnNames="user_id"
            referencedTableName="users" referencedColumnNames="id"
            constraintName="fk_yolanda_token_user"/>
    </changeSet>

    <changeSet id="080-2" author="claude">
        <comment>Add source and external_id columns to body_measurements for Yolanda sync</comment>
        <addColumn tableName="body_measurements">
            <column name="source" type="VARCHAR(20)" defaultValue="MANUAL">
                <constraints nullable="false"/>
            </column>
            <column name="external_id" type="VARCHAR(100)">
                <constraints nullable="true" unique="true" uniqueConstraintName="uk_body_measurements_external_id"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
