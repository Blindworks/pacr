<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="084-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_events"/></not>
        </preConditions>
        <comment>Create group_events table for trainer-organized group runs and events</comment>
        <createTable tableName="group_events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="event_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="true"/>
            </column>
            <column name="location_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="latitude" type="DOUBLE">
                <constraints nullable="true"/>
            </column>
            <column name="longitude" type="DOUBLE">
                <constraints nullable="true"/>
            </column>
            <column name="distance_km" type="DOUBLE">
                <constraints nullable="true"/>
            </column>
            <column name="max_participants" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="cost_cents" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="cost_currency" type="VARCHAR(3)" defaultValue="EUR">
                <constraints nullable="false"/>
            </column>
            <column name="difficulty" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="group_events" baseColumnNames="trainer_id"
            referencedTableName="users" referencedColumnNames="id"
            constraintName="fk_group_events_trainer"/>
        <createIndex tableName="group_events" indexName="idx_group_events_trainer">
            <column name="trainer_id"/>
        </createIndex>
        <createIndex tableName="group_events" indexName="idx_group_events_date_status">
            <column name="event_date"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="group_events" indexName="idx_group_events_lat_lon">
            <column name="latitude"/>
            <column name="longitude"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
