<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="086-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="group_events" columnName="pace_min_seconds_per_km"/></not>
        </preConditions>
        <comment>Add pace range columns to group_events for specifying target pace</comment>
        <addColumn tableName="group_events">
            <column name="pace_min_seconds_per_km" type="INT">
                <constraints nullable="true"/>
            </column>
            <column name="pace_max_seconds_per_km" type="INT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
