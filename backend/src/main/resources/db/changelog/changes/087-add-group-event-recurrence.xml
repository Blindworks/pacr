<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Add recurrence fields to group_events -->
    <changeSet id="087-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="group_events" columnName="rrule"/></not>
        </preConditions>
        <comment>Add RRULE recurrence pattern to group_events</comment>
        <addColumn tableName="group_events">
            <column name="rrule" type="VARCHAR(500)"/>
            <column name="recurrence_end_date" type="DATE"/>
        </addColumn>
    </changeSet>

    <!-- Create group_event_exceptions table for cancelled occurrences -->
    <changeSet id="087-2" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_event_exceptions"/></not>
        </preConditions>
        <comment>Create group_event_exceptions table for cancelled occurrences of recurring events</comment>
        <createTable tableName="group_event_exceptions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="exception_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="group_event_exceptions" baseColumnNames="event_id"
            referencedTableName="group_events" referencedColumnNames="id"
            constraintName="fk_group_event_exc_event"/>
        <addUniqueConstraint tableName="group_event_exceptions"
            columnNames="event_id, exception_date"
            constraintName="uk_group_event_exc_event_date"/>
        <createIndex tableName="group_event_exceptions" indexName="idx_group_event_exc_event">
            <column name="event_id"/>
        </createIndex>
    </changeSet>

    <!-- Add occurrence_date to registrations for recurring event support -->
    <changeSet id="087-3" author="claude">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="group_event_registrations" columnName="occurrence_date"/></not>
        </preConditions>
        <comment>Add occurrence_date to registrations for recurring event support</comment>
        <addColumn tableName="group_event_registrations">
            <column name="occurrence_date" type="DATE"/>
        </addColumn>
        <!-- Drop old unique constraint and create new one including occurrence_date -->
        <dropUniqueConstraint tableName="group_event_registrations"
            constraintName="uk_group_event_reg_event_user"/>
        <addUniqueConstraint tableName="group_event_registrations"
            columnNames="event_id, user_id, occurrence_date"
            constraintName="uk_group_event_reg_event_user_occ"/>
    </changeSet>

</databaseChangeLog>
