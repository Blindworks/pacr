<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="091-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="friendships"/>
            </not>
        </preConditions>
        <comment>Create friendships table for friend connections between users</comment>
        <createTable tableName="friendships">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="requester_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_friendship_requester"
                             references="users(id)"/>
            </column>
            <column name="addressee_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_friendship_addressee"
                             references="users(id)"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="responded_at" type="DATETIME"/>
        </createTable>

        <addUniqueConstraint tableName="friendships"
                             columnNames="requester_id, addressee_id"
                             constraintName="uk_friendship_pair"/>

        <createIndex tableName="friendships" indexName="idx_friendship_addressee_status">
            <column name="addressee_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex tableName="friendships" indexName="idx_friendship_requester_status">
            <column name="requester_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
