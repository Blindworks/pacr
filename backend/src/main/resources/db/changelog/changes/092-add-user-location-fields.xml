<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="092-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="latitude"/>
            </not>
        </preConditions>
        <comment>Add latitude column to users for nearby discovery</comment>
        <addColumn tableName="users">
            <column name="latitude" type="DOUBLE"/>
        </addColumn>
    </changeSet>

    <changeSet id="092-2" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="longitude"/>
            </not>
        </preConditions>
        <comment>Add longitude column to users for nearby discovery</comment>
        <addColumn tableName="users">
            <column name="longitude" type="DOUBLE"/>
        </addColumn>
    </changeSet>

    <changeSet id="092-3" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="location_updated_at"/>
            </not>
        </preConditions>
        <comment>Add location_updated_at column to users</comment>
        <addColumn tableName="users">
            <column name="location_updated_at" type="DATETIME"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
