<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="095-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="community_routes" columnName="source_activity_id"/>
        </preConditions>
        <comment>Allow admin-uploaded community routes without a source activity</comment>
        <dropNotNullConstraint tableName="community_routes"
                               columnName="source_activity_id"
                               columnDataType="BIGINT"/>
    </changeSet>

</databaseChangeLog>
