<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="097-1" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="community_routes" columnName="admin_uploaded"/>
            </not>
        </preConditions>
        <comment>Flag whether a community route was uploaded via admin panel</comment>
        <addColumn tableName="community_routes">
            <column name="admin_uploaded" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
