<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="100-plan-adjustments-cascade-fk" author="dev">
        <preConditions onFail="MARK_RAN">
            <foreignKeyConstraintExists foreignKeyName="fk_plan_adj_entry" foreignKeyTableName="plan_adjustments"/>
        </preConditions>
        <comment>Replace FK on plan_adjustments.user_training_entry_id with ON DELETE SET NULL</comment>
        <dropForeignKeyConstraint baseTableName="plan_adjustments" constraintName="fk_plan_adj_entry"/>
        <addForeignKeyConstraint
            baseTableName="plan_adjustments"
            baseColumnNames="user_training_entry_id"
            constraintName="fk_plan_adj_entry"
            referencedTableName="user_training_entries"
            referencedColumnNames="id"
            onDelete="SET NULL"/>
    </changeSet>
</databaseChangeLog>
