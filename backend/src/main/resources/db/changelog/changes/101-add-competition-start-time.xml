<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="101-add-competition-start-time" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="competitions" columnName="start_time"/>
            </not>
        </preConditions>
        <comment>Add start_time column to competitions table</comment>
        <addColumn tableName="competitions">
            <column name="start_time" type="TIME"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
