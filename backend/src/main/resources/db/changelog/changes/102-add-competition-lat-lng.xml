<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="102-add-competition-lat-lng" author="trainingsplan">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="competitions" columnName="latitude"/>
            </not>
        </preConditions>
        <comment>Add latitude and longitude columns to competitions table</comment>
        <addColumn tableName="competitions">
            <column name="latitude" type="DOUBLE"/>
            <column name="longitude" type="DOUBLE"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
