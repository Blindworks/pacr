<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="105-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="training_steps" columnName="repetitions"/>
        </preConditions>
        <comment>Drop unused repetitions column from training_steps</comment>
        <dropColumn tableName="training_steps" columnName="repetitions"/>
    </changeSet>

</databaseChangeLog>
