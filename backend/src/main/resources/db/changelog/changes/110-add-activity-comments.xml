<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="110-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="activity_comments"/>
            </not>
        </preConditions>
        <comment>Create activity_comments table for News Hub social interactions</comment>
        <createTable tableName="activity_comments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="completed_training_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_activity_comment_ct" references="completed_trainings(id)" deleteCascade="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_activity_comment_user" references="users(id)" deleteCascade="true"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
