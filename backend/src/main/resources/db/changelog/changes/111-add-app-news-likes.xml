<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="111-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="app_news_likes"/>
            </not>
        </preConditions>
        <comment>Create app_news_likes table (one like per user per news item)</comment>
        <createTable tableName="app_news_likes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="news_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_app_news_like_news" references="app_news(id)" deleteCascade="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_app_news_like_user" references="users(id)" deleteCascade="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="app_news_likes"
                             columnNames="news_id, user_id"
                             constraintName="uk_app_news_like_pair"/>
    </changeSet>

</databaseChangeLog>
