<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="115-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="preferred_news_languages"/>
            </not>
        </preConditions>
        <comment>Add preferred_news_languages column to users (comma-separated list of language codes)</comment>
        <addColumn tableName="users">
            <column name="preferred_news_languages" type="VARCHAR(50)" defaultValue="de,en"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
