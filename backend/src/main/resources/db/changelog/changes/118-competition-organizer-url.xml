<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="118-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="competitions" columnName="organizer_url"/>
            </not>
        </preConditions>
        <comment>Add organizer_url column to competitions (link to organizer's website)</comment>
        <addColumn tableName="competitions">
            <column name="organizer_url" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
