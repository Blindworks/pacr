<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="124-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="previous_login_at"/>
            </not>
        </preConditions>
        <comment>Track previous login timestamp to detect new Strava activities since last session</comment>
        <addColumn tableName="users">
            <column name="previous_login_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
