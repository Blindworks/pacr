<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="126-1" author="benedikt">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="group_events" columnName="event_image_filename"/>
            </not>
        </preConditions>
        <comment>Add event_image_filename column to group_events for trainer event icon/image upload</comment>
        <addColumn tableName="group_events">
            <column name="event_image_filename" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
